   "source": [
    "class Person:\n",
    "    def __init__(self, name, age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "\n",
    "    def get_name(self):\n",
    "        print(f\"My name is {self.name}\")\n",
    "\n",
    "    def get_age(self):\n",
    "        print(f\"My age is {self.age}\")\n",
    "\n",
    "\n",
    "jadi = Person(\"Minoo\", 30)\n",
    "jadi.get_name()\n",
    "jadi.get_age()"
   ]
  }
 ],
